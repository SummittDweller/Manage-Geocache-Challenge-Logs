# Manage Geocache Challenge Logs environment template
# Copy this file to .env and fill in values if you plan to use env-based defaults.
# The current app flow uses UI fields + Flet client storage by default.

# Geocaching credentials
GEOCACHING_USERNAME=your_geocaching_username
GEOCACHING_PASSWORD=your_geocaching_password

# Optional absolute path to a Firefox profile directory
# Example (macOS): /Users/you/Library/Application Support/Firefox/Profiles/xxxx.default-release
FIREFOX_PROFILE_PATH=

# Optional flag for app behavior if you wire env loading in code
# Accepted values: true or false
REMEMBER_GEOCACHING_PASSWORD=false

# Debug scan stop count:
# 0 = don't stop early (default)
# N = stop after N matched candidates and keep browser open
# Examples: 1, 5, 10
GC_DEBUG_STOP_AFTER_MATCH_COUNT=0

# Legacy fallback (optional, kept for compatibility):
# true/1 = stop after 1, false/0 = don't stop
GC_DEBUG_STOP_AFTER_FIRST_LOG=false
